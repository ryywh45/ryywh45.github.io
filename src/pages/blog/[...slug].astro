---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`/${post.id.includes('/') ? post.id.split('/')[0] + '/' : ''}${post.data.title}`}>
  <article>
    <header class="mb-8">
      <time datetime={post.data.pubDate.toISOString().slice(0, 10)} class="text-sm text-zinc-500 font-mono">
        {post.data.pubDate.toISOString().slice(0, 10)}
      </time>
      <h1 class="text-2xl font-bold mt-1 text-zinc-100">{post.data.title}</h1>
    </header>
    <div class="prose prose-invert prose-zinc max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>

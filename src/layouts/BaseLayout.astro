---
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface Props {
  title?: string;
}

const { title = 'james@blog' } = Astro.props;

const posts = await getCollection('blog');
const categories = [...new Set(
  posts
    .map(p => p.id.includes('/') ? p.id.split('/')[0] : null)
    .filter(Boolean)
)].sort() as string[];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rawPath = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';

// Compute the display path for the prompt
let promptPath: string;
if (rawPath === '/') {
  promptPath = '~/';
} else if (rawPath.startsWith('/about')) {
  promptPath = '~/about.md';
} else if (rawPath.startsWith('/blog/')) {
  // /blog/category/slug → ~/category/slug
  promptPath = '~' + rawPath.replace('/blog', '');
} else {
  promptPath = '~' + rawPath + '/';
}

// Determine which nav item should be active
let activeSection: string;
if (rawPath.startsWith('/blog/')) {
  const parts = rawPath.replace('/blog/', '').split('/');
  // /blog/dev/slug → /dev  |  /blog/slug → /
  activeSection = parts.length >= 2 ? '/' + parts[0] : '/';
} else {
  activeSection = rawPath;
}

function isActive(href: string) {
  return activeSection === (href.replace(/\/$/, '') || '/');
}
---

<!doctype html>
<html lang="zh-Hant" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="128x128" href={`${base}/favicon-128x128.png`} />
    <link rel="icon" type="image/png" sizes="96x96" href={`${base}/favicon-96x96.png`} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="shortcut icon" href={`${base}/favicon.ico`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}/site.webmanifest`} />
    <title>{title}</title>
  </head>
  <body class="bg-zinc-900 text-zinc-100 min-h-screen">
    <header class="border-b border-zinc-800">
      <div class="max-w-3xl mx-auto px-6 py-5 space-y-2 font-mono text-sm">

        <!-- Line 1: prompt with current path -->
        <div class="flex items-center gap-0">
          <span class="text-green-400 font-bold">james@blog</span>
          <span class="text-white">:</span>
          <span class="text-blue-400 font-bold">{promptPath}</span>
          <span class="text-white">&nbsp;$&nbsp;</span>
          <span class="w-[0.45em] h-[1em] bg-zinc-100 animate-pulse inline-block align-text-bottom"></span>
        </div>

        <!-- Line 2: directory nav -->
        <div class="flex items-center gap-3 flex-wrap">
          <a
            href={`${base}/`}
            class:list={['transition-colors', isActive('/') ? 'text-zinc-100' : 'text-zinc-500 hover:text-zinc-300']}
          >~/</a>

          {categories.map(cat => (
            <a
              href={`${base}/${cat}/`}
              class:list={['transition-colors', isActive(`/${cat}`) ? 'text-zinc-100' : 'text-zinc-500 hover:text-zinc-300']}
            >~/{cat}/</a>
          ))}

          <a
            href={`${base}/about/`}
            class:list={['transition-colors', isActive('/about') ? 'text-zinc-100' : 'text-zinc-500 hover:text-zinc-300']}
          >~/about.md</a>
        </div>

      </div>
    </header>
    <main class="max-w-3xl mx-auto px-6 py-10">
      <slot />
    </main>
  </body>
</html>
